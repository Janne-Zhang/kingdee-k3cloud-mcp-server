{
  "name": "kingdee-k3cloud-dev-mcp-server",
  "version": "1.0.7",
  "description": "金蝶云星空企业版开发服务",
  "bin": {
    "kingdee-k3cloud-dev-mcp-server": "./dist/index.js"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rmdir /s /q dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "kingdee",
    "k3cloud",
    "金蝶",
    "金蝶云星空",
    "二次开发"
  ],
  "author": "janne-zhang",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.31.0",
    "express": "^4.21.2",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^11.12.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.19.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}