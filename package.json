{
  "name": "kingdee-k3cloud-mcp-server",
  "version": "0.0.2",
  "description": "金蝶云星空企业版服务",
  "main": "dist/index.js",
    "scripts": {
      "start": "tsx src/index.ts",
      "build": "tsc",
      "dev": "tsx watch src/index.ts",
      "lint": "eslint src/",
      "lint:fix": "eslint src/ --fix",
      "format": "prettier --write \"src/**/*.ts\"",
      "format:check": "prettier --check \"src/**/*.ts\"",
      "clean": "rm -rf dist/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "kingdee",
    "k3cloud",
    "金蝶",
    "金蝶云星空"
  ],
  "author": "janne-zhang",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "eslint": "^10.2.1",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.59.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
